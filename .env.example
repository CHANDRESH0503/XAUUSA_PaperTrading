TWELVE_DATA_API_KEY=your_twelve_data_api_key_here
XAUUSD_SYMBOL=XAU/USD
PORT=4173

# Bind to all interfaces so the dashboard is reachable from your browser.
# On a VPS: set this to 0.0.0.0 then open the port in your firewall.
# Locally: leave as 127.0.0.1 (default).
HOST=0.0.0.0

# Optional: POST signal JSON here on every directional signal or paper action.
# Works with Telegram webhooks, Slack incoming webhooks, Make.com, etc.
# Leave blank to disable.
SIGNAL_WEBHOOK_URL=
